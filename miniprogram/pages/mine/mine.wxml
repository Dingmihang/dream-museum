<!-- 我的 -->
<view class="profile-header">
  <image class="profile-avatar" src="{{user.avatar || '/assets/default-avatar.png'}}" mode="aspectFill" />
  <view class="profile-name">{{user.nickname || '梦行者'}}</view>
</view>

<view class="quota-row">
  <view class="quota-item">
    <view class="quota-num">{{user.free_count}}/{{user.daily_free}}</view>
    <view class="quota-label">今日免费次数</view>
  </view>
  <view class="quota-item">
    <view class="quota-num">{{user.credit_count}}</view>
    <view class="quota-label">广告额度</view>
  </view>
</view>

<view style="text-align:center;padding:8px">
  <button class="btn-ad" bindtap="watchAd" style="font-size:14px;padding:8px 20px">📺 观看广告 +1 次数</button>
</view>

<view class="divider"></view>

<!-- Tab 切换 -->
<view style="text-align:center;border-bottom:1px solid #1e1e3a;padding:8px">
  <text class="btn-outline {{tab==='dreams'?'liked':''}}" bindtap="switchTab" data-tab="dreams" style="margin:0 4px">我的梦境</text>
  <text class="btn-outline {{tab==='favs'?'faved':''}}" bindtap="switchTab" data-tab="favs" style="margin:0 4px">我的收藏</text>
</view>

<!-- 我的梦境 -->
<view wx:if="{{tab === 'dreams'}}">
  <block wx:if="{{dreams.length > 0}}">
    <view style="text-align:center;padding:16px">
      <block wx:for="{{dreams}}" wx:key="id">
        <view class="dream-card" bindtap="goDetail" data-id="{{item.id}}">
          <image class="dream-card-image" src="{{item.image_url}}" mode="aspectFill" />
          <view class="dream-card-title">{{item.dream_title}}</view>
          <view class="dream-card-footer">
            <text class="dream-card-author" style="color:{{item.is_public ? '#6bcf6b' : '#606080'}}">
              {{item.is_public ? '已公开' : '未公开'}}
            </text>
            <text class="dream-card-like" catchtap="deleteDream" data-id="{{item.id}}">🗑️</text>
          </view>
        </view>
      </block>
    </view>
  </block>
  <block wx:else>
    <view class="empty-wrap"><text class="empty-text">还没有梦境记录</text></view>
  </block>
</view>

<!-- 我的收藏 -->
<view wx:if="{{tab === 'favs'}}">
  <block wx:if="{{favs.length > 0}}">
    <view style="text-align:center;padding:16px">
      <block wx:for="{{favs}}" wx:key="id">
        <view class="dream-card" bindtap="goDetail" data-id="{{item.id}}">
          <image class="dream-card-image" src="{{item.image_url}}" mode="aspectFill" />
          <view class="dream-card-title">{{item.dream_title}}</view>
          <view class="dream-card-author">{{item.nickname || '梦行者'}}</view>
        </view>
      </block>
    </view>
  </block>
  <block wx:else>
    <view class="empty-wrap"><text class="empty-text">还没有收藏梦境</text></view>
  </block>
</view>
