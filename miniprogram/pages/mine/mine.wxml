<!-- 我的 — 可编辑头像和昵称 -->
<view class="profile-header">
  <button class="profile-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
    <image class="profile-avatar" src="{{user.avatar || '/assets/default-avatar.png'}}" mode="aspectFill" />
  </button>
  <view style="text-align:center;margin-top:10px">
    <input class="nickname-input" type="nickname" placeholder="点击设置昵称" value="{{editName}}" bindinput="onNameInput" bindblur="saveNickname" maxlength="20" />
  </view>
</view>

<view class="quota-row">
  <view class="quota-item">
    <view class="quota-num">{{user.free_count}}/{{user.daily_free}}</view>
    <view class="quota-label">今日免费次数</view>
  </view>
  <view class="quota-item">
    <view class="quota-num">{{dreamCount}}</view>
    <view class="quota-label">我的梦境</view>
  </view>
</view>

<view class="tab-row">
  <text class="tab-btn {{tab==='dreams'?'on':''}}" bindtap="switchTab" data-tab="dreams">我的梦境</text>
  <text class="tab-btn {{tab==='favs'?'on':''}}" bindtap="switchTab" data-tab="favs">我的收藏</text>
</view>

<!-- 我的梦境 -->
<view wx:if="{{tab === 'dreams'}}">
  <block wx:if="{{dreams.length > 0}}">
    <view style="text-align:center;padding:12px 8px 40px">
      <block wx:for="{{dreams}}" wx:key="id">
        <view class="dream-card" bindtap="goDetail" data-id="{{item.id}}">
          <image class="dream-card-image" src="{{item.image_url}}" mode="aspectFill" />
          <view class="dream-card-body">
            <view class="dream-card-title">{{item.dream_title}}</view>
            <view style="font-size:12px;color:{{item.is_public ? '#8CB88A' : '#B0A090'}};margin-bottom:4px">
              {{item.is_public ? '✨ 已公开' : '🔒 未公开'}}
            </view>
            <text class="text-sm" catchtap="deleteDream" data-id="{{item.id}}">🗑️ 删除</text>
          </view>
        </view>
      </block>
    </view>
  </block>
  <block wx:else>
    <view class="empty-wrap">
      <text class="empty-icon">💭</text>
      <text class="empty-text">还没有梦境记录<br/>去创作第一个梦吧</text>
    </view>
  </block>
</view>

<!-- 我的收藏 -->
<view wx:if="{{tab === 'favs'}}">
  <block wx:if="{{favs.length > 0}}">
    <view style="text-align:center;padding:12px 8px 40px">
      <block wx:for="{{favs}}" wx:key="id">
        <view class="dream-card" bindtap="goDetail" data-id="{{item.id}}">
          <image class="dream-card-image" src="{{item.image_url}}" mode="aspectFill" />
          <view class="dream-card-body">
            <view class="dream-card-title">{{item.dream_title}}</view>
            <view class="dream-card-footer">{{item.nickname || '梦行者'}} · ❤️ {{item.like_count || 0}}</view>
          </view>
        </view>
      </block>
    </view>
  </block>
  <block wx:else>
    <view class="empty-wrap">
      <text class="empty-icon">⭐</text>
      <text class="empty-text">还没有收藏<br/>去梦境大厅逛逛吧</text>
    </view>
  </block>
</view>

<!-- 退出登录 -->
<view style="text-align:center;padding:32px 0 40px">
  <text style="color:#C0C0C0;font-size:14px" bindtap="logout">退出登录</text>
</view>

<!-- 编辑昵称弹窗 -->
<view wx:if="{{showNameEdit}}" class="modal-mask" bindtap="closeNameEdit">
  <view class="modal-box">
    <view class="modal-title">修改昵称</view>
    <input style="display:block;width:88%;margin:12px auto;padding:10px 14px;border:1px solid #EDE8E0;border-radius:12px;font-size:15px;text-align:center" 
      placeholder="输入新昵称" value="{{editName}}" bindinput="onNameInput" maxlength="20" />
    <button class="btn-primary" bindtap="saveNickname" style="display:inline-block;width:auto;padding:10px 28px;font-size:14px">保存</button>
  </view>
</view>
