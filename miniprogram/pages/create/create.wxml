<!-- 创造梦境 -->
<block wx:if="{{!generated}}">
  <!-- 输入阶段 -->
  <view class="create-wrap">
    <view class="title-md">描述你的梦境</view>
    <textarea class="input-area" placeholder="例如：我梦见小时候的学校变成一片森林，天空有巨大的月亮..."
      value="{{prompt}}" bindinput="onInput" maxlength="200" auto-height />
    <text class="text-sm" style="display:block;text-align:right;padding:0 16px">{{prompt.length}}/200</text>

    <view class="title-md">选择梦境风格</view>
    <scroll-view class="style-row" scroll-x>
      <block wx:for="{{styles}}" wx:key="*this">
        <text class="style-chip {{style === item ? 'active' : ''}}" bindtap="pickStyle" data-style="{{item}}">{{item}}</text>
      </block>
    </scroll-view>

    <view style="text-align:center;padding:24px">
      <button class="btn-primary" bindtap="generate" disabled="{{generating || !prompt}}">
        {{generating ? '生成中...' : '✨ 生成梦境'}}
      </button>
      <view style="margin-top:8px">
        <text class="text-sm">今日免费：{{quota.free_count}}/1 · 广告额度：{{quota.credit_count}}</text>
      </view>
    </view>
  </view>
</block>

<block wx:elif="{{generating}}">
  <!-- 生成中 -->
  <view class="progress-wrap">
    <view style="font-size:48px">🌙</view>
    <view class="progress-text">{{progressText}}</view>
    <view style="margin-top:20px">
      <text class="text-sm">AI 正在解析你的梦境...</text>
    </view>
  </view>
</block>

<block wx:else>
  <!-- 结果展示 -->
  <view class="generate-result">
    <image class="generate-image" src="{{result.image_url}}" mode="widthFix" />
    <view class="generate-title">{{result.dream_title}}</view>
    <view class="generate-tags">
      <block wx:for="{{result.dream_tags}}" wx:key="*this" wx:for-item="tag">
        <text class="dream-card-tag">{{tag}}</text>
      </block>
    </view>
    <view class="generate-analysis">{{result.dream_analysis}}</view>

    <view style="text-align:center;padding:12px">
      <button class="btn-primary" bindtap="publish" style="display:inline-block;width:auto;margin:4px 6px">📤 公开发布</button>
      <button class="btn-outline" bindtap="regenerate" style="display:inline-block;width:auto;margin:4px 6px">🔄 再生成</button>
    </view>
  </view>
</block>

<!-- 无额度弹窗 -->
<view wx:if="{{showAdModal}}" class="ad-modal" style="position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.7);z-index:100;text-align:center">
  <view style="background:#12122a;border-radius:16px;padding:24px;margin:40% 20px;display:inline-block;width:80%">
    <view style="font-size:18px;color:#e0e0ff;margin-bottom:8px">今日免费次数已用完</view>
    <view style="font-size:14px;color:#8080a0;margin-bottom:20px">观看广告可获得 1 次梦境生成机会</view>
    <button class="btn-ad" bindtap="watchAd">📺 观看广告获得次数</button>
    <view style="margin-top:12px">
      <text style="color:#606080;font-size:13px" bindtap="closeAdModal">取消</text>
    </view>
  </view>
</view>
