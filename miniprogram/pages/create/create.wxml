<!-- 创造梦境 -->
<block wx:if="{{!generated && !generating}}">
  <view class="create-wrap">
    <view class="title-md">🌙 描述你的梦境</view>
    <textarea class="input-area" placeholder="例如：我梦见小时候的学校变成一片森林，天空有巨大的月亮..."
      value="{{prompt}}" bindinput="onInput" maxlength="200" auto-height />
    <text class="text-sm" style="display:block;text-align:right;padding:0 24px">{{prompt.length}}/200</text>

    <view class="title-md" style="padding-top:20px">🎨 选择梦境风格</view>
    <scroll-view class="style-row" scroll-x>
      <block wx:for="{{styles}}" wx:key="*this">
        <text class="style-chip {{style === item ? 'active' : ''}}" bindtap="pickStyle" data-style="{{item}}">{{item}}</text>
      </block>
    </scroll-view>

    <view style="text-align:center;padding:32px 0">
      <button class="btn-primary" bindtap="generate" disabled="{{generating || !prompt}}">
        {{generating ? '生成中...' : '✨ 生成梦境'}}
      </button>
      <view style="margin-top:12px">
        <text class="text-sm">今日剩余 {{quota.free_count}}/{{quota.daily_free}} 次</text>
      </view>
    </view>
  </view>
</block>

<block wx:elif="{{generating}}">
  <view class="progress-wrap">
    <text class="progress-icon">🌙</text>
    <view class="progress-bar-wrap">
      <view class="progress-bar-fill" style="width:{{progressPct}}%"></view>
    </view>
    <view class="progress-text">{{progressText}}</view>
    <view style="margin-top:16px">
      <text class="text-sm">AI 正在解析你的梦境...</text>
    </view>
  </view>
</block>

<block wx:else>
  <view class="generate-result">
    <!-- 生成结果图片，加载失败显示占位 -->
    <image wx:if="{{!resultImgFailed}}" class="generate-image" src="{{result.image_url}}" mode="widthFix" binderror="onResultImageError" />
    <view wx:else class="generate-image-placeholder"></view>
    
    <view class="generate-title">{{result.dream_title}}</view>
    <view class="generate-tags">
      <block wx:for="{{result.dream_tags}}" wx:key="*this" wx:for-item="tag">
        <text class="dream-card-tag" style="font-size:12px;padding:4px 12px;margin:4px 4px">{{tag}}</text>
      </block>
    </view>
    <view class="generate-analysis">{{result.dream_analysis}}</view>

    <view wx:if="{{genFailed}}" style="text-align:center;padding:12px 20px">
      <text class="text-sm" style="color:#B08070">生成失败，请检查网络后重试</text>
      <button class="btn-outline" bindtap="regenerate" style="display:inline-block;width:auto;margin:12px 8px">🔄 再试一次</button>
    </view>

    <view wx:else class="result-actions">
      <button class="btn-primary" bindtap="publish" style="display:inline-block;width:auto;margin:6px 8px;font-size:15px;padding:12px 32px">📤 公开发布</button>
      <button class="btn-outline" bindtap="regenerate" style="display:inline-block;width:auto;margin:6px 8px">🔄 再做一个</button>
    </view>
  </view>
</block>

<!-- 广告弹窗（次数用完自动弹出） -->
<view wx:if="{{showAdModal}}" class="modal-mask">
  <view class="modal-box">
    <view class="modal-title">🌟 今日次数已用完</view>
    <view class="modal-desc">观看广告即可获得一次梦境生成机会</view>
    <button class="btn-ad" bindtap="watchAd" style="display:inline-block;width:auto;padding:12px 32px">📺 观看广告 +1 次</button>
    <view style="margin-top:16px">
      <text style="color:#B0A090;font-size:13px" bindtap="closeAdModal">下次再说</text>
    </view>
  </view>
</view>
