/* 梦境博物馆 - 温暖治愈风全局样式 */

page {
  background-color: #FFFFFF;
  color: #3A3A3A;
  font-size: 14px;
  min-height: 100vh;
}

/* ========== 文本 ========== */
.title-lg {
  font-size: 22px;
  font-weight: 600;
  color: #3A3A3A;
  text-align: center;
  padding: 24px 0 12px;
  letter-spacing: 2px;
}
.title-md {
  font-size: 16px;
  font-weight: 600;
  color: #4A4A4A;
  padding: 16px 20px 8px;
}
.text-body {
  font-size: 14px;
  color: #6A6A6A;
  line-height: 1.8;
}
.text-sm {
  font-size: 12px;
  color: #A0A0A0;
}
.text-accent {
  color: #C8A27A;
}

/* ========== 按钮 ========== */
.btn-primary {
  display: inline-block;
  background: #C8A27A;
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 500;
  padding: 14px 40px;
  border-radius: 28px;
  text-align: center;
  margin: 8px auto;
  box-shadow: 0 2px 12px rgba(200, 162, 122, 0.25);
  border: none;
  letter-spacing: 1px;
}
.btn-outline {
  display: inline-block;
  background: transparent;
  color: #C8A27A;
  font-size: 14px;
  padding: 10px 24px;
  border: 1px solid #E8D5C0;
  border-radius: 24px;
  text-align: center;
  margin: 4px auto;
}
.btn-ad {
  display: inline-block;
  background: #FFF3D6;
  color: #8B6F3A;
  font-size: 14px;
  font-weight: 500;
  padding: 10px 24px;
  border-radius: 22px;
  text-align: center;
  border: 1px solid #F0D9A0;
}

/* ========== 卡片 ========== */
.card {
  background: #FFFFFF;
  border-radius: 16px;
  margin: 10px 16px;
  overflow: hidden;
  box-shadow: 0 2px 16px rgba(0, 0, 0, 0.04);
}

/* ========== 梦境瀑布流卡片 ========== */
.dream-card {
  display: inline-block;
  width: 44%;
  background: #FFFFFF;
  border-radius: 16px;
  margin: 8px 2.5%;
  overflow: hidden;
  vertical-align: top;
  box-shadow: 0 1px 8px rgba(0, 0, 0, 0.04);
}
.dream-card-image {
  width: 100%;
  height: 200px;
  background: #F5EDE3;
  display: block;
}
.dream-card-body {
  padding: 10px 12px 12px;
}
.dream-card-title {
  font-size: 14px;
  color: #3A3A3A;
  font-weight: 600;
  margin-bottom: 4px;
  line-height: 1.4;
}
.dream-card-tags {
  margin-bottom: 6px;
}
.dream-card-tag {
  display: inline-block;
  font-size: 10px;
  color: #C8A27A;
  background: #FFF3D6;
  padding: 2px 8px;
  border-radius: 10px;
  margin: 2px 4px 2px 0;
}
.dream-card-footer {
  font-size: 11px;
  color: #B0A090;
}

/* ========== 梦境大厅装饰 ========== */
.hall-header {
  text-align: center;
  padding: 32px 24px 20px;
}
.hall-icon {
  font-size: 40px;
  display: block;
  margin-bottom: 8px;
}
.hall-title {
  font-size: 20px;
  color: #3A3A3A;
  font-weight: 600;
  letter-spacing: 2px;
}
.hall-subtitle {
  font-size: 13px;
  color: #B0A090;
  margin-top: 6px;
}

/* ========== 搜索 ========== */
.search-wrap {
  padding: 0 24px 12px;
  text-align: center;
}
.search-box {
  display: block;
  width: 90%;
  margin: 0 auto;
  background: #F8F6F2;
  border-radius: 24px;
  padding: 10px 18px;
  border: 1px solid #EDE8E0;
}
.search-input {
  display: inline-block;
  width: 100%;
  font-size: 14px;
  color: #3A3A3A;
  background: transparent;
  text-align: left;
}

/* ========== 加载中 ========== */
.loading-wrap {
  text-align: center;
  padding: 60px 20px;
}
.loading-dot {
  display: inline-block;
  width: 8px;
  height: 8px;
  background: #D4C4A8;
  border-radius: 50%;
  margin: 0 4px;
  animation: dotBounce 1.2s infinite ease-in-out;
}
.loading-dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes dotBounce {
  0%, 80%, 100% { transform: translateY(0); opacity: 0.3; }
  40% { transform: translateY(-8px); opacity: 1; }
}
.loading-text {
  font-size: 14px;
  color: #B0A090;
  margin-top: 12px;
}

/* ========== 空状态 ========== */
.empty-wrap {
  text-align: center;
  padding: 80px 20px;
}
.empty-icon {
  font-size: 48px;
  display: block;
  margin-bottom: 12px;
  opacity: 0.6;
}
.empty-text {
  font-size: 15px;
  color: #B0A090;
  line-height: 1.8;
}

/* ========== 输入框 ========== */
.input-area {
  display: block;
  width: 88%;
  background: #FFFFFF;
  border: 1px solid #F0E6D8;
  border-radius: 16px;
  color: #3A3A3A;
  font-size: 15px;
  padding: 16px;
  margin: 10px auto;
  box-sizing: border-box;
  min-height: 120px;
  box-shadow: 0 1px 8px rgba(0, 0, 0, 0.02);
}

/* ========== 分隔线 ========== */
.divider {
  border-top: 1px solid #F0E6D8;
  margin: 16px 0;
}

/* ========== 生成页 ========== */
.create-wrap {
  padding: 20px;
}
.style-row {
  text-align: center;
  padding: 8px 0 16px;
  white-space: nowrap;
  overflow-x: auto;
}
.style-chip {
  display: inline-block;
  background: #FFFFFF;
  color: #8A7A6A;
  font-size: 13px;
  padding: 8px 16px;
  border-radius: 20px;
  margin: 4px 6px;
  border: 1px solid #F0E6D8;
  box-shadow: 0 1px 4px rgba(0,0,0,0.02);
}
.style-chip.active {
  background: #FFF3D6;
  color: #8B6F3A;
  border-color: #E0C68A;
  font-weight: 500;
}

/* ========== 生成进度 ========== */
.progress-wrap {
  text-align: center;
  padding: 60px 40px;
}
.progress-icon {
  font-size: 56px;
  display: block;
  margin-bottom: 20px;
}
.progress-bar-wrap {
  display: inline-block;
  width: 200px;
  height: 4px;
  background: #F0E6D8;
  border-radius: 2px;
  overflow: hidden;
  margin: 16px auto;
}
.progress-bar-fill {
  height: 100%;
  background: #C8A27A;
  border-radius: 2px;
  transition: width 0.5s ease;
}
.progress-text {
  font-size: 15px;
  color: #8A7A6A;
  margin-top: 12px;
}

/* ========== 生成结果 ========== */
.generate-result {
  padding: 0 20px 40px;
}
.generate-image {
  width: 100%;
  border-radius: 16px;
  margin: 0 auto;
  display: block;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
}
.generate-title {
  font-size: 22px;
  color: #3A3A3A;
  text-align: center;
  margin: 20px 0 8px;
  font-weight: 600;
  letter-spacing: 2px;
}
.generate-tags {
  text-align: center;
  padding: 4px 0 12px;
}
.generate-analysis {
  font-size: 15px;
  color: #6A6A6A;
  line-height: 2;
  text-align: left;
  padding: 20px;
  background: #FFFFFF;
  border-radius: 16px;
  margin: 12px auto;
  width: 88%;
  box-shadow: 0 1px 12px rgba(0, 0, 0, 0.03);
  border: 1px solid #F5EDE3;
}
.result-actions {
  text-align: center;
  padding: 16px 0;
}

/* ========== 详情页 ========== */
.detail-image {
  width: 100%;
  display: block;
}
.detail-info {
  padding: 20px 20px 0;
}
.detail-title {
  font-size: 22px;
  color: #3A3A3A;
  font-weight: 600;
  margin-bottom: 6px;
  letter-spacing: 1px;
}
.detail-meta {
  font-size: 13px;
  color: #B0A090;
  margin-bottom: 16px;
}
.detail-analysis {
  font-size: 15px;
  color: #5A5A5A;
  line-height: 2;
  margin: 16px 0;
  padding: 16px 20px;
  background: #FFFFFF;
  border-radius: 14px;
  box-shadow: 0 1px 8px rgba(0,0,0,0.03);
  border: 1px solid #F5EDE3;
}
.detail-source {
  font-size: 13px;
  color: #B0A090;
  padding: 12px 0;
  line-height: 1.6;
}
.detail-actions {
  text-align: center;
  padding: 24px 20px;
}
.action-btn {
  display: inline-block;
  background: #FFFFFF;
  border: 1px solid #F0E6D8;
  border-radius: 22px;
  color: #8A7A6A;
  font-size: 14px;
  padding: 10px 24px;
  margin: 0 6px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.02);
}

/* ========== 我的页面 ========== */
.profile-header {
  text-align: center;
  padding: 40px 20px 24px;
}
.profile-avatar-btn {
  display: block;
  width: 72px;
  height: 72px;
  margin: 0 auto;
  padding: 0;
  background: transparent;
  border: none;
  line-height: 1;
}
.profile-avatar-btn::after {
  border: none;
}
.profile-avatar {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: #F5EDE3;
  display: block;
  border: 3px solid #FFF3D6;
}
.nickname-input {
  display: inline-block;
  width: 180px;
  font-size: 18px;
  color: #3A3A3A;
  font-weight: 600;
  text-align: center;
  background: transparent;
  height: 36px;
  line-height: 36px;
}
.quota-row {
  text-align: center;
  padding: 0 20px 16px;
}
.quota-item {
  display: inline-block;
  width: 45%;
  padding: 16px 0;
  margin: 0 2%;
  background: #FFFFFF;
  border-radius: 14px;
  box-shadow: 0 1px 8px rgba(0,0,0,0.03);
  border: 1px solid #F5EDE3;
}
.quota-num {
  font-size: 24px;
  color: #C8A27A;
  font-weight: 600;
}
.quota-label {
  font-size: 11px;
  color: #B0A090;
  margin-top: 4px;
}

/* ========== Tab 切换 ========== */
.tab-row {
  text-align: center;
  padding: 0 16px 12px;
  border-bottom: 1px solid #F5EDE3;
  margin-bottom: 4px;
}
.tab-btn {
  display: inline-block;
  font-size: 14px;
  color: #B0A090;
  padding: 8px 20px;
  margin: 0 4px;
  border-bottom: 2px solid transparent;
}
.tab-btn.on {
  color: #C8A27A;
  border-bottom-color: #C8A27A;
  font-weight: 500;
}

/* ========== 弹窗 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.35);
  z-index: 100;
  text-align: center;
}
.modal-box {
  background: #FFFFFF;
  border-radius: 20px;
  padding: 32px 24px;
  margin: 40% 20px;
  display: inline-block;
  width: 80%;
  box-shadow: 0 8px 40px rgba(0,0,0,0.08);
}
.modal-title {
  font-size: 18px;
  color: #3A3A3A;
  font-weight: 600;
  margin-bottom: 8px;
}
.modal-desc {
  font-size: 14px;
  color: #8A7A6A;
  margin-bottom: 24px;
  line-height: 1.6;
}

/* ========== 详情页操作按钮状态 ========== */
.action-btn.liked {
  color: #E88B8B;
  border-color: #F5D0D0;
  background: #FFF5F5;
}
.action-btn.faved {
  color: #D4A456;
  border-color: #F0D9A0;
  background: #FFFDF5;
}

/* ========== 底部安全区 ========== */
.safe-bottom {
  padding-bottom: 40px;
}
